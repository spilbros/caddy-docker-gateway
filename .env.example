# Base domain — wildcard cert covers *.your-domain.com and your-domain.com itself.
BASE_DOMAIN=example.com

# Cloudflare API Token (Scoped Token, NOT the Global API Key).
# Permissions: Zone > DNS > Edit, Zone Resources > Include > <your BASE_DOMAIN zone>
CLOUDFLARE_API_TOKEN=your_token_here

# Email for ACME notifications from Let's Encrypt (e.g. upcoming cert expiry)
ACME_EMAIL=your@email.com
